# Copy to .env and fill values. DO NOT COMMIT .env
LM_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_API_KEY=sk-lm-REPLACE_ME

# Model A: small/tool model (must be loaded in LM Studio)
ROUTER_MODEL=REPLACE_TOOL_MODEL_ID

# Model B: Shine model (must be loaded in LM Studio)
SHINE_MODEL=REPLACE_SHINE_MODEL_ID

# Router API port
PORT=8787

# MCP config
MCP_JSON_PATH=E:\Shine Voice\router_api\mcp.json
MCP_SERVER_NAME=persistent-ai-memory

# Optional: prompt config path (defaults to ./prompts/shine_persona.json)
# SHINE_PROMPT_PATH=E:\Shine Voice\router_api\prompts\shine_persona.json
